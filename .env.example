# ─── MRIF Environment Configuration ───────────────────────────────────────────

# Core identity
MRIF_CORE_ID=CORE_001
MRIF_LOG_LEVEL=INFO

# Persistence
MRIF_DB_URL=sqlite:///mrif.db

# Memory limits
MRIF_WORKING_MEMORY_LIMIT=1000

# Evolution thresholds
MRIF_MAX_FORKS=10
MRIF_EVOLUTION_THRESHOLD=0.8

# Research pipeline
MRIF_MAX_HYPOTHESES=100
MRIF_SIMULATION_TIMEOUT=300

# Safety
MRIF_AUDIT_ENABLED=true
MRIF_REPRODUCIBILITY_MODE=false

# Reality engine
MRIF_MAX_REALITIES=50

# Timeline engine
MRIF_MAX_TIMELINE_DEPTH=20
